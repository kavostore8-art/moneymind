# ============================================
# MoneyMind Environment Variables
# ============================================

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
API_VERSION=1.0.0
APP_NAME=MoneyMind

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=moneymind_user
DATABASE_PASSWORD=secure_password_change_this
DATABASE_NAME=moneymind_dev
DATABASE_URL="postgresql://moneymind_user:secure_password_change_this@localhost:5432/moneymind_dev"

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long_please
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_long_please
JWT_REFRESH_EXPIRY=7d

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:8080

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug

# ============================================
# Email Service (Optional)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@moneymind.com

# ============================================
# Google OAuth (Optional)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# Deployment URLs
# ============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
